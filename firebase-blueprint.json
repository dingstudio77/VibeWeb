{
  "entities": {
    "Portfolio": {
      "title": "Portfolio",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "url": { "type": "string", "format": "uri" },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "description", "image"]
    },
    "Admin": {
      "title": "Admin",
      "description": "System administrator",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "portfolios": {
      "schema": "Portfolio",
      "description": "Collection of portfolio projects"
    },
    "admins": {
      "schema": "Admin",
      "description": "Collection of authorized admin users"
    }
  }
}
